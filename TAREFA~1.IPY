   "source": [
    "# ======================================================\n",
    "# ITEM 1 — FAIXAS DE LATITUDE\n",
    "# ======================================================\n",
    "\n",
    "# Criando duas faixas de latitude\n",
    "sinasc['faixa_latitude'] = np.where(\n",
    "    sinasc['munResLat'] > -10.5,\n",
    "    'Acima de -10.5',\n",
    "    'Abaixo de -10.5'\n",
    ")\n",
    "\n",
    "print(\"Faixas criadas com sucesso:\")\n",
    "print(sinasc['faixa_latitude'].value_counts())\n",
    "\n",
    "# Escolhendo duas variáveis numéricas ainda não usadas\n",
    "variaveis = ['PESO', 'APGAR1']\n",
    "\n",
    "# Aplicando groupby\n",
    "resultado_lat = (\n",
    "    sinasc\n",
    "    .groupby('faixa_latitude')[variaveis]\n",
    "    .agg(['sum','mean','min','max','median','std','var'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print(\"\\nResumo estatístico por faixa de latitude:\")\n",
    "display(resultado_lat)"
   ]
  },
