      "baixo     1540\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "sinasc['faixa_pib'] = pd.cut(\n",
    "    sinasc['PIB'],\n",
    "    bins=[0, 300000, 1000000, 21000000],\n",
    "    labels=['baixo', 'medio', 'alto'],\n",
    "    include_lowest=True\n",
    ")\n",
    "\n",
    "print('Contagem por faixa de PIB:')\n",
    "print(sinasc['faixa_pib'].value_counts(dropna=False))"
   ]
  },
