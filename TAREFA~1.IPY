    "resultado_pib = (\n",
    "    sinasc\n",
    "    .groupby('faixa_pib')[['IDADEMAE', 'PESO']]\n",
    "    .agg(['mean', 'min', 'max', 'median', 'std', 'var'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "display(resultado_pib)"
   ]
