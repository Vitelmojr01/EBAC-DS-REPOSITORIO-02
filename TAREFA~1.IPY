    "# ======================================================\n",
    "# ITEM 4 — GRÁFICO REGIÕES\n",
    "# ======================================================\n",
    "\n",
    "sinasc['regiao'] = sinasc['munResNome'].map(imediatas)\n",
    "\n",
    "idade_regiao = (\n",
    "    sinasc\n",
    "    .groupby(['DTNASC','regiao'])['IDADEMAE']\n",
    "    .mean()\n",
    "    .unstack()\n",
    ")\n",
    "\n",
    "idade_regiao.plot(figsize=(10,5))\n",
    "\n",
    "plt.title(\"Idade média das mães por região\")\n",
    "plt.ylabel(\"Idade média\")\n",
    "\n",
    "plt.show()"
   ]
