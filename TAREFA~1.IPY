   "source": [
    "sinasc['IDH'] = sinasc['munResNome'].map(idh)\n",
    "\n",
    "sinasc['faixa_idh'] = pd.cut(\n",
    "    sinasc['IDH'],\n",
    "    bins=[0, 0.6, 0.7, 0.8, 1],\n",
    "    labels=['baixo', 'medio', 'alto', 'muito_alto'],\n",
    "    include_lowest=True\n",
    ")\n",
    "\n",
    "print('Contagem por faixa de IDH:')\n",
    "print(sinasc['faixa_idh'].value_counts(dropna=False))\n",
    "\n",
    "resultado_idh = (\n",
    "    sinasc\n",
    "    .groupby('faixa_idh')[['IDADEMAE', 'PESO']]\n",
    "    .agg(['mean', 'min', 'max', 'median', 'std', 'var'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "display(resultado_idh)"
   ]
  },
