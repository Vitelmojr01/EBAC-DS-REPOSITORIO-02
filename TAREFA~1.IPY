   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# carregar a base\n",
    "sinasc = pd.read_csv('.ipynb_checkpoints/SINASC_RO_2019.csv')\n",
    "\n",
    "# converter a data\n",
    "sinasc['DTNASC'] = pd.to_datetime(sinasc['DTNASC'])\n",
    "\n",
    "print('Base carregada com sucesso.')\n",
    "print(f'Linhas: {sinasc.shape[0]}')\n",
    "print(f'Colunas: {sinasc.shape[1]}')\n",
    "display(sinasc.head())"
   ]
  },
