    "# ======================================================\n",
    "# ITEM 3 — FAIXAS DE ALTITUDE\n",
    "# ======================================================\n",
    "\n",
    "sinasc['faixa_altitude'] = pd.cut(\n",
    "    sinasc['munResAlt'],\n",
    "    3\n",
    ")\n",
    "\n",
    "print(\"Faixas de altitude:\")\n",
    "print(sinasc['faixa_altitude'].value_counts())\n",
    "\n",
    "variaveis = ['PESO','IDADEMAE']\n",
    "\n",
    "resultado_alt = (\n",
    "    sinasc\n",
    "    .groupby('faixa_altitude')[variaveis]\n",
    "    .agg(['sum','mean','min','max','median','std','var'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print(\"\\nResumo por altitude:\")\n",
    "display(resultado_alt)"
   ]
