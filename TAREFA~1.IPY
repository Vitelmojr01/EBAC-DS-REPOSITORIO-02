   "source": [
    "# ITEM 2 — FAIXAS DE AREA DOS MUNICIPIOS\n",
    "\n",
    "# criando as faixas\n",
    "sinasc['faixa_area'] = np.where(\n",
    "    sinasc['munResArea'] > 3000,\n",
    "    'Acima de 3000',\n",
    "    'Abaixo de 3000'\n",
    ")\n",
    "\n",
    "print('Faixas criadas com sucesso:')\n",
    "print(sinasc['faixa_area'].value_counts())\n",
    "\n",
    "# escolhendo duas variáveis numéricas ainda não usadas\n",
    "variaveis = ['IDADEMAE','QTDGESTANT']\n",
    "\n",
    "# aplicando groupby\n",
    "resultado_area = (\n",
    "    sinasc\n",
    "    .groupby('faixa_area')[variaveis]\n",
    "    .agg(['sum','mean','min','max','median','std','var'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\nResumo estatístico por faixa de área:')\n",
    "display(resultado_area)"
   ]
  },
