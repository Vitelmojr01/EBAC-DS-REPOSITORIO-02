   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# =========================================================\n",
    "# ANÁLISE: CASAIS DE PRIMEIRA VIAGEM x CASAIS EXPERIÊNTES\n",
    "# OBJETIVO:\n",
    "# verificar se casais de primeira viagem têm mais perdas\n",
    "# ou se as perdas são mais comuns em casais com histórico reprodutivo\n",
    "# =========================================================\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 1) Garantir que a data está no formato correto\n",
    "# ---------------------------------------------------------\n",
    "sinasc['DTNASC'] = pd.to_datetime(sinasc['DTNASC'])\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 2) Filtrar apenas março\n",
    "# ---------------------------------------------------------\n",
    "sinasc_marco = sinasc[sinasc['DTNASC'].dt.month == 3].copy()\n",
    "\n",
    "print('=' * 70)\n",
    "print('1) FILTRO DE MARÇO')\n",
    "print('=' * 70)\n",
    "print(f'Registros em março: {sinasc_marco.shape[0]}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 3) Descobrir o município com mais nascimentos em março\n",
    "# ---------------------------------------------------------\n",
    "nascimentos_marco = sinasc_marco.groupby('munResNome').size().sort_values(ascending=False)\n",
    "\n",
    "municipio_mais_marco = nascimentos_marco.index[0]\n",
    "qtd_mais_marco = nascimentos_marco.iloc[0]\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('2) MUNICÍPIO COM MAIS NASCIMENTOS EM MARÇO')\n",
    "print('=' * 70)\n",
    "print(f'Município: {municipio_mais_marco}')\n",
    "print(f'Nascimentos: {qtd_mais_marco}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 4) Filtrar somente esse município\n",
    "# ---------------------------------------------------------\n",
    "dados = sinasc_marco[sinasc_marco['munResNome'] == municipio_mais_marco].copy()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('3) BASE FINAL DA ANÁLISE')\n",
    "print('=' * 70)\n",
    "print(f'Município analisado: {municipio_mais_marco}')\n",
    "print(f'Quantidade de registros: {dados.shape[0]}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 5) Criar os grupos:\n",
    "# primeira viagem = sem filhos vivos\n",
    "# experientes = com pelo menos 1 filho vivo\n",
    "# ---------------------------------------------------------\n",
    "primeira_viagem = dados[dados['QTDFILVIVO'] == 0].copy()\n",
    "experientes = dados[dados['QTDFILVIVO'] > 0].copy()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('4) TAMANHO DOS GRUPOS')\n",
    "print('=' * 70)\n",
    "print(f'Casais de primeira viagem (QTDFILVIVO = 0): {primeira_viagem.shape[0]}')\n",
    "print(f'Casais experientes (QTDFILVIVO > 0): {experientes.shape[0]}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 6) Comparar a média de filhos mortos entre os grupos\n",
    "# ---------------------------------------------------------\n",
    "media_perdas_primeira = primeira_viagem['QTDFILMORT'].mean().round(3)\n",
    "media_perdas_experientes = experientes['QTDFILMORT'].mean().round(3)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('5) MÉDIA DE FILHOS MORTOS POR GRUPO')\n",
    "print('=' * 70)\n",
    "print(f'Média de filhos mortos - primeira viagem: {media_perdas_primeira}')\n",
    "print(f'Média de filhos mortos - experientes: {media_perdas_experientes}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 7) Distribuição de filhos mortos no grupo de primeira viagem\n",
    "# ---------------------------------------------------------\n",
    "dist_primeira = primeira_viagem['QTDFILMORT'].value_counts().sort_index()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('6) DISTRIBUIÇÃO DE FILHOS MORTOS - PRIMEIRA VIAGEM')\n",
    "print('=' * 70)\n",
    "print(dist_primeira)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 8) Distribuição de filhos mortos no grupo experiente\n",
    "# ---------------------------------------------------------\n",
    "dist_experientes = experientes['QTDFILMORT'].value_counts().sort_index()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('7) DISTRIBUIÇÃO DE FILHOS MORTOS - EXPERIÊNTES')\n",
    "print('=' * 70)\n",
    "print(dist_experientes)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 9) Percentual de casais de primeira viagem sem nenhuma perda\n",
    "# ---------------------------------------------------------\n",
    "total_primeira = primeira_viagem.shape[0]\n",
    "sem_perdas_primeira = primeira_viagem[primeira_viagem['QTDFILMORT'] == 0].shape[0]\n",
    "com_perdas_primeira = primeira_viagem[primeira_viagem['QTDFILMORT'] > 0].shape[0]\n",
    "\n",
    "perc_sem_perdas_primeira = round((sem_perdas_primeira / total_primeira) * 100, 2) if total_primeira > 0 else 0\n",
    "perc_com_perdas_primeira = round((com_perdas_primeira / total_primeira) * 100, 2) if total_primeira > 0 else 0\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('8) PERCENTUAL DE PRIMEIRA VIAGEM COM E SEM PERDAS')\n",
    "print('=' * 70)\n",
    "print(f'Total primeira viagem: {total_primeira}')\n",
    "print(f'Sem perdas anteriores: {sem_perdas_primeira} ({perc_sem_perdas_primeira}%)')\n",
    "print(f'Com perdas anteriores: {com_perdas_primeira} ({perc_com_perdas_primeira}%)')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 10) Percentual de experientes com e sem perdas\n",
    "# ---------------------------------------------------------\n",
    "total_experientes = experientes.shape[0]\n",
    "sem_perdas_experientes = experientes[experientes['QTDFILMORT'] == 0].shape[0]\n",
    "com_perdas_experientes = experientes[experientes['QTDFILMORT'] > 0].shape[0]\n",
    "\n",
    "perc_sem_perdas_experientes = round((sem_perdas_experientes / total_experientes) * 100, 2) if total_experientes > 0 else 0\n",
    "perc_com_perdas_experientes = round((com_perdas_experientes / total_experientes) * 100, 2) if total_experientes > 0 else 0\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('9) PERCENTUAL DE EXPERIÊNTES COM E SEM PERDAS')\n",
    "print('=' * 70)\n",
    "print(f'Total experientes: {total_experientes}')\n",
    "print(f'Sem perdas anteriores: {sem_perdas_experientes} ({perc_sem_perdas_experientes}%)')\n",
    "print(f'Com perdas anteriores: {com_perdas_experientes} ({perc_com_perdas_experientes}%)')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 11) Comparar idade média de mães e pais entre os grupos\n",
    "# ---------------------------------------------------------\n",
    "idade_media_grupos = pd.DataFrame({\n",
    "    'Primeira_Viagem': primeira_viagem[['IDADEMAE', 'IDADEPAI']].mean().round(2),\n",
    "    'Experientes': experientes[['IDADEMAE', 'IDADEPAI']].mean().round(2)\n",
    "})\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('10) IDADE MÉDIA DOS PAIS E MÃES POR GRUPO')\n",
    "print('=' * 70)\n",
    "print(idade_media_grupos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 12) Resumo estatístico por grupo\n",
    "# ---------------------------------------------------------\n",
    "resumo_por_grupo = dados.groupby(dados['QTDFILVIVO'] == 0)[['QTDFILMORT', 'IDADEMAE', 'IDADEPAI']].mean().round(2)\n",
    "resumo_por_grupo.index = ['Experientes', 'Primeira Viagem']\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('11) RESUMO MÉDIO POR GRUPO')\n",
    "print('=' * 70)\n",
    "print(resumo_por_grupo)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 13) Correlação entre filhos vivos e filhos mortos\n",
    "# ---------------------------------------------------------\n",
    "corr_filhos = dados[['QTDFILVIVO', 'QTDFILMORT']].corr().round(4)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('12) CORRELAÇÃO ENTRE FILHOS VIVOS E FILHOS MORTOS')\n",
    "print('=' * 70)\n",
    "print(corr_filhos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 14) Comparar perdas por faixa de idade da mãe em cada grupo\n",
    "# ---------------------------------------------------------\n",
    "primeira_viagem_faixa_mae = (\n",
    "    primeira_viagem.groupby(pd.cut(primeira_viagem['IDADEMAE'], 5))['QTDFILMORT']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "experientes_faixa_mae = (\n",
    "    experientes.groupby(pd.cut(experientes['IDADEMAE'], 5))['QTDFILMORT']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('13) FILHOS MORTOS POR FAIXA DE IDADE DA MÃE - PRIMEIRA VIAGEM')\n",
    "print('=' * 70)\n",
    "print(primeira_viagem_faixa_mae)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('14) FILHOS MORTOS POR FAIXA DE IDADE DA MÃE - EXPERIÊNTES')\n",
    "print('=' * 70)\n",
    "print(experientes_faixa_mae)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 15) Comparar perdas por faixa de idade do pai em cada grupo\n",
    "# ---------------------------------------------------------\n",
    "primeira_viagem_faixa_pai = (\n",
    "    primeira_viagem.groupby(pd.cut(primeira_viagem['IDADEPAI'], 5))['QTDFILMORT']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "experientes_faixa_pai = (\n",
    "    experientes.groupby(pd.cut(experientes['IDADEPAI'], 5))['QTDFILMORT']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('15) FILHOS MORTOS POR FAIXA DE IDADE DO PAI - PRIMEIRA VIAGEM')\n",
    "print('=' * 70)\n",
    "print(primeira_viagem_faixa_pai)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('16) FILHOS MORTOS POR FAIXA DE IDADE DO PAI - EXPERIÊNTES')\n",
    "print('=' * 70)\n",
    "print(experientes_faixa_pai)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 16) Gráfico de barras - média de filhos mortos por grupo\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('17) GRÁFICO: MÉDIA DE FILHOS MORTOS POR GRUPO')\n",
    "print('=' * 70)\n",
    "\n",
    "medias_grupos = pd.Series({\n",
    "    'Primeira Viagem': media_perdas_primeira,\n",
    "    'Experientes': media_perdas_experientes\n",
    "})\n",
    "\n",
    "medias_grupos.plot(kind='bar', figsize=(7, 5))\n",
    "plt.xlabel('Grupo')\n",
    "plt.ylabel('Média de Filhos Mortos')\n",
    "plt.title('Média de Filhos Mortos: Primeira Viagem vs Experientes')\n",
    "plt.xticks(rotation=0)\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 17) Gráfico - distribuição de filhos mortos na primeira viagem\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('18) GRÁFICO: DISTRIBUIÇÃO DE FILHOS MORTOS - PRIMEIRA VIAGEM')\n",
    "print('=' * 70)\n",
    "\n",
    "dist_primeira.plot(kind='bar', figsize=(7, 5))\n",
    "plt.xlabel('Quantidade de Filhos Mortos')\n",
    "plt.ylabel('Número de Casos')\n",
    "plt.title('Distribuição de Filhos Mortos - Primeira Viagem')\n",
    "plt.xticks(rotation=0)\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 18) Gráfico - distribuição de filhos mortos nos experientes\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('19) GRÁFICO: DISTRIBUIÇÃO DE FILHOS MORTOS - EXPERIÊNTES')\n",
    "print('=' * 70)\n",
    "\n",
    "dist_experientes.plot(kind='bar', figsize=(7, 5))\n",
    "plt.xlabel('Quantidade de Filhos Mortos')\n",
    "plt.ylabel('Número de Casos')\n",
    "plt.title('Distribuição de Filhos Mortos - Experientes')\n",
    "plt.xticks(rotation=0)\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 19) Comparação do percentual com perdas\n",
    "# ---------------------------------------------------------\n",
    "percentuais_perdas = pd.DataFrame({\n",
    "    'Grupo': ['Primeira Viagem', 'Experientes'],\n",
    "    'Percentual com perdas': [perc_com_perdas_primeira, perc_com_perdas_experientes],\n",
    "    'Percentual sem perdas': [perc_sem_perdas_primeira, perc_sem_perdas_experientes]\n",
    "})\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('20) TABELA FINAL DE PERCENTUAIS')\n",
    "print('=' * 70)\n",
    "print(percentuais_perdas)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 20) Gráfico de percentuais\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('21) GRÁFICO: PERCENTUAL COM E SEM PERDAS')\n",
    "print('=' * 70)\n",
    "\n",
    "percentuais_plot = percentuais_perdas.set_index('Grupo')\n",
    "percentuais_plot.plot(kind='bar', figsize=(8, 5))\n",
    "plt.xlabel('Grupo')\n",
    "plt.ylabel('Percentual')\n",
    "plt.title('Percentual com e sem perdas por grupo')\n",
    "plt.xticks(rotation=0)\n",
    "plt.show()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('FIM DA ANÁLISE')\n",
    "print('=' * 70)\n",
    "print('RESULTADOS.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "REPONDENDO O ITEM 5 - ANALISES\n",
    "\n",
    "\n",
    "#Análise demográfica dos nascimentos – SINASC 2019\n",
    "\n",
    " Identificação da análise\n",
    "\n",
    "**Município analisado:** Porto Velho – RO  \n",
    "**Período analisado:** Março de 2019  \n",
    "**Base utilizada:** SINASC_RO_2019  \n",
    "**Total de nascimentos analisados:** 744  \n",
    "\n",
    "Contexto do estudo\n",
    "\n",
    "Esta análise tem como objetivo investigar padrões demográficos relacionados à idade dos pais, \n",
    "número de filhos vivos e histórico de filhos mortos, buscando identificar possíveis relações \n",
    "entre experiência reprodutiva e ocorrência de perdas anteriores."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "ANALISE 1 - RELAÇÃO IDADE DOS PAIS E PERDAS\n",
    "\n",
    "Conclusão da Análise 1 — Relação entre idade dos pais e perdas\n",
    "\n",
    "A análise mostrou que existe uma relação positiva fraca entre a idade dos pais e a quantidade de filhos mortos, indicando que pais mais velhos tendem a apresentar ligeiramente maior histórico de perdas. No entanto, como essa correlação é baixa, a idade isoladamente não pode ser considerada um fator determinante, sendo mais provável que o maior número de perdas esteja associado ao maior tempo reprodutivo e ao número de gestações ao longo da vida."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "ANALISE 2 - CASAIS MAIS VELHOR E PERDAS E CASAIS \"PRIMEIRA VIAVEM E PERDAS\"\n",
    "\n",
    "Conclusão da Análise 2 — Casais mais velhos, casais de primeira viagem e perdas\n",
    "\n",
    "A comparação entre casais de primeira viagem e casais experientes mostrou que casais com filhos anteriores apresentam maior média de perdas, indicando que o número de filhos mortos está mais relacionado ao histórico reprodutivo do que à inexperiência dos pais. Além disso, observou-se que casais experientes possuem idade média maior, reforçando que o aumento das perdas está mais associado ao tempo reprodutivo do que à falta de experiência."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "CONCLUSÃO FINAL: A idade em si, tanto de pais ou mães e a idade do casal, não é um fator determinante para o aumento de perdas. Assim como casais inexperientes não possuem um histórico de perdas maior pela inexperiênca pelo contrário (CONCLUSÃO IMPORTANTE). Mas esse aumento é pelo tempo reprodutivo do casal, mais gestações, mais chances de perdas."
   ]
  },
