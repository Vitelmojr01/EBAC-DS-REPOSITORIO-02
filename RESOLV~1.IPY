   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# =========================================================\n",
    "# ANÁLISES DO ITEM 4 - RELAÇÃO ENTRE IDADE DOS PAIS,\n",
    "# FILHOS MORTOS E FILHOS VIVOS\n",
    "# =========================================================\n",
    "\n",
    "# Garantir que a coluna de data está no formato datetime\n",
    "sinasc['DTNASC'] = pd.to_datetime(sinasc['DTNASC'])\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 1) Filtrar apenas os nascimentos do mês de março\n",
    "# ---------------------------------------------------------\n",
    "sinasc_marco = sinasc[sinasc['DTNASC'].dt.month == 3].copy()\n",
    "\n",
    "print('=' * 70)\n",
    "print('1) FILTRO DE MARÇO')\n",
    "print('=' * 70)\n",
    "print(f'Quantidade de registros em março: {sinasc_marco.shape[0]}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 2) Descobrir o município com mais nascimentos em março\n",
    "# ---------------------------------------------------------\n",
    "nascimentos_marco = sinasc_marco.groupby('munResNome').size().sort_values(ascending=False)\n",
    "\n",
    "municipio_mais_marco = nascimentos_marco.index[0]\n",
    "qtd_mais_marco = nascimentos_marco.iloc[0]\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('2) MUNICÍPIO COM MAIS NASCIMENTOS EM MARÇO')\n",
    "print('=' * 70)\n",
    "print(f'Município: {municipio_mais_marco}')\n",
    "print(f'Quantidade de nascimentos: {qtd_mais_marco}')\n",
    "\n",
    "print('\\nTop 10 municípios com mais nascimentos em março:')\n",
    "print(nascimentos_marco.head(10))\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 3) Filtrar apenas os dados desse município\n",
    "# ---------------------------------------------------------\n",
    "dados = sinasc_marco[sinasc_marco['munResNome'] == municipio_mais_marco].copy()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('3) BASE FINAL USADA NAS ANÁLISES')\n",
    "print('=' * 70)\n",
    "print(f'Município analisado: {municipio_mais_marco}')\n",
    "print(f'Quantidade de registros desse município em março: {dados.shape[0]}')\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 4) Resumo estatístico principal\n",
    "# ---------------------------------------------------------\n",
    "resumo_principal = (\n",
    "    dados[['QTDFILVIVO', 'QTDFILMORT', 'IDADEPAI', 'IDADEMAE']]\n",
    "    .agg(['mean', 'min', 'max'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('4) RESUMO ESTATÍSTICO PRINCIPAL')\n",
    "print('=' * 70)\n",
    "print(resumo_principal)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 5) Correlação entre idade do pai e filhos mortos\n",
    "# ---------------------------------------------------------\n",
    "corr_pai_filhos_mortos = dados[['IDADEPAI', 'QTDFILMORT']].corr().round(4)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('5) CORRELAÇÃO: IDADE DO PAI x FILHOS MORTOS')\n",
    "print('=' * 70)\n",
    "print(corr_pai_filhos_mortos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 6) Correlação entre idade da mãe e filhos mortos\n",
    "# ---------------------------------------------------------\n",
    "corr_mae_filhos_mortos = dados[['IDADEMAE', 'QTDFILMORT']].corr().round(4)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('6) CORRELAÇÃO: IDADE DA MÃE x FILHOS MORTOS')\n",
    "print('=' * 70)\n",
    "print(corr_mae_filhos_mortos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 7) Correlação entre idade do pai e filhos vivos\n",
    "# ---------------------------------------------------------\n",
    "corr_pai_filhos_vivos = dados[['IDADEPAI', 'QTDFILVIVO']].corr().round(4)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('7) CORRELAÇÃO: IDADE DO PAI x FILHOS VIVOS')\n",
    "print('=' * 70)\n",
    "print(corr_pai_filhos_vivos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 8) Correlação geral entre as principais variáveis\n",
    "# ---------------------------------------------------------\n",
    "corr_geral = dados[['IDADEMAE', 'IDADEPAI', 'QTDFILVIVO', 'QTDFILMORT']].corr().round(4)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('8) CORRELAÇÃO GERAL')\n",
    "print('=' * 70)\n",
    "print(corr_geral)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 9) Média de filhos mortos por idade do pai\n",
    "# ---------------------------------------------------------\n",
    "media_filhos_mortos_por_idade_pai = (\n",
    "    dados.groupby('IDADEPAI')['QTDFILMORT']\n",
    "    .mean()\n",
    "    .sort_values(ascending=False)\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('9) MÉDIA DE FILHOS MORTOS POR IDADE DO PAI (TOP 15)')\n",
    "print('=' * 70)\n",
    "print(media_filhos_mortos_por_idade_pai.head(15))\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 10) Média de filhos mortos por idade da mãe\n",
    "# ---------------------------------------------------------\n",
    "media_filhos_mortos_por_idade_mae = (\n",
    "    dados.groupby('IDADEMAE')['QTDFILMORT']\n",
    "    .mean()\n",
    "    .sort_values(ascending=False)\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('10) MÉDIA DE FILHOS MORTOS POR IDADE DA MÃE (TOP 15)')\n",
    "print('=' * 70)\n",
    "print(media_filhos_mortos_por_idade_mae.head(15))\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 11) Média de filhos mortos por faixa de idade do pai\n",
    "# ---------------------------------------------------------\n",
    "faixas_pai_filhos_mortos = (\n",
    "    dados.groupby(pd.cut(dados['IDADEPAI'], 5))['QTDFILMORT']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('11) MÉDIA DE FILHOS MORTOS POR FAIXA DE IDADE DO PAI')\n",
    "print('=' * 70)\n",
    "print(faixas_pai_filhos_mortos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 12) Média de filhos vivos por faixa de idade do pai\n",
    "# ---------------------------------------------------------\n",
    "faixas_pai_filhos_vivos = (\n",
    "    dados.groupby(pd.cut(dados['IDADEPAI'], 5))['QTDFILVIVO']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('12) MÉDIA DE FILHOS VIVOS POR FAIXA DE IDADE DO PAI')\n",
    "print('=' * 70)\n",
    "print(faixas_pai_filhos_vivos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 13) Média de filhos mortos por faixa de idade da mãe\n",
    "# ---------------------------------------------------------\n",
    "faixas_mae_filhos_mortos = (\n",
    "    dados.groupby(pd.cut(dados['IDADEMAE'], 5))['QTDFILMORT']\n",
    "    .mean()\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('13) MÉDIA DE FILHOS MORTOS POR FAIXA DE IDADE DA MÃE')\n",
    "print('=' * 70)\n",
    "print(faixas_mae_filhos_mortos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 14) Distribuição da quantidade de filhos mortos\n",
    "# ---------------------------------------------------------\n",
    "distribuicao_filhos_mortos = dados['QTDFILMORT'].value_counts().sort_index()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('14) DISTRIBUIÇÃO DE FILHOS MORTOS')\n",
    "print('=' * 70)\n",
    "print(distribuicao_filhos_mortos)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 15) Estatísticas descritivas da idade do pai\n",
    "# ---------------------------------------------------------\n",
    "descricao_idade_pai = dados['IDADEPAI'].describe().round(2)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('15) DESCRIÇÃO DA IDADE DO PAI')\n",
    "print('=' * 70)\n",
    "print(descricao_idade_pai)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 16) Estatísticas descritivas da idade da mãe\n",
    "# ---------------------------------------------------------\n",
    "descricao_idade_mae = dados['IDADEMAE'].describe().round(2)\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('16) DESCRIÇÃO DA IDADE DA MÃE')\n",
    "print('=' * 70)\n",
    "print(descricao_idade_mae)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 17) Gráfico de dispersão: idade do pai x filhos mortos\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('17) GRÁFICO: IDADE DO PAI x FILHOS MORTOS')\n",
    "print('=' * 70)\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.scatter(dados['IDADEPAI'], dados['QTDFILMORT'])\n",
    "plt.xlabel('Idade do Pai')\n",
    "plt.ylabel('Quantidade de Filhos Mortos')\n",
    "plt.title('Idade do Pai x Filhos Mortos')\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 18) Gráfico de dispersão: idade da mãe x filhos mortos\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('18) GRÁFICO: IDADE DA MÃE x FILHOS MORTOS')\n",
    "print('=' * 70)\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.scatter(dados['IDADEMAE'], dados['QTDFILMORT'])\n",
    "plt.xlabel('Idade da Mãe')\n",
    "plt.ylabel('Quantidade de Filhos Mortos')\n",
    "plt.title('Idade da Mãe x Filhos Mortos')\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 19) Gráfico de barras: filhos mortos por faixa de idade do pai\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('19) GRÁFICO: MÉDIA DE FILHOS MORTOS POR FAIXA DE IDADE DO PAI')\n",
    "print('=' * 70)\n",
    "\n",
    "faixas_pai_filhos_mortos.plot(kind='bar', figsize=(8, 5))\n",
    "plt.xlabel('Faixa de Idade do Pai')\n",
    "plt.ylabel('Média de Filhos Mortos')\n",
    "plt.title('Média de Filhos Mortos por Faixa de Idade do Pai')\n",
    "plt.xticks(rotation=45)\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 20) Gráfico de barras: filhos mortos por faixa de idade da mãe\n",
    "# ---------------------------------------------------------\n",
    "print('\\n' + '=' * 70)\n",
    "print('20) GRÁFICO: MÉDIA DE FILHOS MORTOS POR FAIXA DE IDADE DA MÃE')\n",
    "print('=' * 70)\n",
    "\n",
    "faixas_mae_filhos_mortos.plot(kind='bar', figsize=(8, 5))\n",
    "plt.xlabel('Faixa de Idade da Mãe')\n",
    "plt.ylabel('Média de Filhos Mortos')\n",
    "plt.title('Média de Filhos Mortos por Faixa de Idade da Mãe')\n",
    "plt.xticks(rotation=45)\n",
    "plt.show()\n",
    "\n",
    "print('\\n' + '=' * 70)\n",
    "print('FIM DAS ANÁLISES')\n",
    "print('=' * 70)\n",
    "print('RESULTADOS.')"
   ]
  },
