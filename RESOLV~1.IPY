   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# carregar a base\n",
    "sinasc = pd.read_csv('.ipynb_checkpoints/SINASC_RO_2019.csv')\n",
    "\n",
    "# transformar a coluna de data em formato datetime\n",
    "sinasc['DTNASC'] = pd.to_datetime(sinasc['DTNASC'])\n",
    "\n",
    "# remover município ignorado para não atrapalhar as análises\n",
    "sinasc = sinasc[sinasc['munResNome'] != 'Município ignorado - RO'].copy()\n",
    "\n",
    "print('Base carregada com sucesso.')\n",
    "print(f'Quantidade de linhas: {sinasc.shape[0]}')\n",
    "print(f'Quantidade de colunas: {sinasc.shape[1]}')\n",
    "print('\\nPrimeiras 5 linhas:')\n",
    "display(sinasc.head())"
   ]
  },
