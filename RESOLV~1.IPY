   "source": [
    "# aniversario meu 01/10, data nascimento 01/10/1974\n",
    "dia_aniversario = 1\n",
    "mes_aniversario = 10\n",
    "\n",
    "filtro_aniversario = sinasc[\n",
    "    (sinasc['DTNASC'].dt.day == dia_aniversario) &\n",
    "    (sinasc['DTNASC'].dt.month == mes_aniversario)\n",
    "].copy()\n",
    "\n",
    "print('TAREFA 2 - Filtro por dia e mês do aniversário')\n",
    "print(f'Data usada no filtro: {dia_aniversario:02d}/{mes_aniversario:02d}')\n",
    "print(f'Quantidade de registros encontrados: {filtro_aniversario.shape[0]}')\n",
    "\n",
    "tarefa2 = (\n",
    "    filtro_aniversario\n",
    "    .groupby(['SEXO', 'ESCMAE'])['PESO']\n",
    "    .mean()\n",
    "    .round(2)\n",
    "    .reset_index()\n",
    "    .sort_values(['SEXO', 'PESO'], ascending=[True, False])\n",
    ")\n",
    "\n",
    "print('\\nPeso médio dos bebês por sexo e escolaridade da mãe:')\n",
    "display(tarefa2)"
   ]
  },
