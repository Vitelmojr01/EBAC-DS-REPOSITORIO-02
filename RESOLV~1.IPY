   "source": [
    "nascimentos_por_municipio = sinasc.groupby('munResNome').size().sort_values()\n",
    "\n",
    "municipio_menos = nascimentos_por_municipio.index[0]\n",
    "qtd_menos = nascimentos_por_municipio.iloc[0]\n",
    "\n",
    "print('TAREFA 3 - Município com menos nascimentos em 2019')\n",
    "print(f'Município com menos nascimentos: {municipio_menos}')\n",
    "print(f'Quantidade de nascimentos: {qtd_menos}')\n",
    "\n",
    "filtro_municipio_menos = sinasc[sinasc['munResNome'] == municipio_menos].copy()\n",
    "\n",
    "tarefa3 = (\n",
    "    filtro_municipio_menos[['IDADEMAE', 'IDADEPAI']]\n",
    "    .agg(['mean', 'min', 'max'])\n",
    "    .round(2)\n",
    ")\n",
    "\n",
    "print('\\nResumo estatístico das idades das mães e dos pais nesse município:')\n",
    "display(tarefa3)"
   ]
  },
