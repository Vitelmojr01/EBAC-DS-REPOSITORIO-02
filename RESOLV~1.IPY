     "text": [
      "Município analisado: Porto Velho\n",
      "Quantidade de registros: 744\n"
     ]
    }
   ],
   "source": [
    "# filtrar apenas março\n",
    "sinasc_marco = sinasc[sinasc['DTNASC'].dt.month == 3].copy()\n",
    "\n",
    "# descobrir município com mais nascimentos\n",
    "nascimentos_marco = sinasc_marco.groupby('munResNome').size().sort_values(ascending=False)\n",
    "\n",
    "municipio_mais_marco = nascimentos_marco.index[0]\n",
    "\n",
    "print(\"Município analisado:\", municipio_mais_marco)\n",
    "\n",
    "# filtrar apenas esse município\n",
    "dados = sinasc_marco[sinasc_marco['munResNome'] == municipio_mais_marco].copy()\n",
    "\n",
    "print(\"Quantidade de registros:\", dados.shape[0])"
   ]
  },
